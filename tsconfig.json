{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "checkJs": true,
    // "declaration": true,
    // "emitDeclarationOnly": true,
    // "outFile": "index.js",
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,

    // "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,

    "types": ["vitest/globals"]
  },
  "include": [
    "configs/**/*.js",
    "configs/**/*-types.ts",
    "tests/fixtures",
    "tests/*.ts",
    "*.config.ts",
    "import-types.d.ts",
    "index.js"
  ]
}
