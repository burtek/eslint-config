{
  "name": "@dtrw/eslint-config",
  "version": "6.1.4",
  "author": "Bartosz Dotryw <burtekdotryw@gmail.com>",
  "description": "Custom eslint configs",
  "keywords": [
    "eslint",
    "config",
    "eslint config",
    "typescript",
    "json"
  ],
  "license": "MIT",
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.16.1",
    "@eslint-react/kit": "5.16.1",
    "@eslint/js": "~10.0.0",
    "@eslint/json": "2.0.1",
    "@next/eslint-plugin-next": "~16.1.0 || ~16.2.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-cypress": "6.4.3",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-jest-dom-ya": "1.0.1",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-lodash": "8.0.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-security-node": "1.1.4",
    "eslint-plugin-testing-library": "7.16.2",
    "globals": "17.7.0",
    "semver": "^7.6.3",
    "typescript-eslint": "8.64.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.1.0",
    "@types/semver": "^7.5.8",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.3.0",
    "exit-code": "^1.0.2",
    "jiti": "^2.4.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "eslint": "^9.6.0 || ^10.0.0",
    "typescript": ">=4.7.4 < 7.0.0"
  },
  "private": false,
  "scripts": {
    "lint": "eslint {configs,rules}/**/*.js",
    "make-types": "rimraf types && tsc --project tsconfig.build.json",
    "test": "vitest run tests/tests.test.ts",
    "preversion": "pnpm test",
    "push": "git push --follow-tags",
    "prerelease": "pnpm test",
    "release": "commit-and-tag-version --config .versionrc.cjs",
    "prerelease:alpha": "pnpm test",
    "release:alpha": "commit-and-tag-version --config .versionrc.alpha.cjs",
    "changelog:cleanup": "./cleanup-changelog.sh"
  },
  "homepage": "https://github.com/burtek/eslint-config#readme",
  "bugs": "https://github.com/burtek/eslint-config/issues",
  "repository": {
    "url": "https://github.com/burtek/eslint-config"
  },
  "engines": {
    "node": "^22.16.0 || >=24",
    "pnpm": ">= 8.0.0"
  },
  "type": "module",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    }
  },
  "packageManager": "pnpm@11.13.1"
}
