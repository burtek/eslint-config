{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "assignees": ["@burtek"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "addLabels": ["security"],
    "assignees": ["@burtek"]
  },
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchDepTypes": ["peerDependencies"],
      "enabled": false
    },
    {
      "matchSourceUrls": ["https://github.com/Rel1cx/eslint-react"],
      "groupName": "@eslint-react monorepo"
    },
    {
      // won't fix release notes but adds a link to actual changelog
      "changelogUrl": "https://github.com/typescript-eslint/typescript-eslint/releases",
      "matchSourceUrls": ["https://github.com/typescript-eslint/typescript-eslint"],
      "groupName": "typescript-eslint monorepo"
    }
  ]
}
